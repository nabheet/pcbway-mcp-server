{
  "name": "pcbway-mcp-server",
  "version": "0.1.0",
  "description": "MCP server for PCBWay Partner API — PCB quotes, assembly quotes, order tracking, and shipping info",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "pcbway-mcp": "dist/index.js"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "prepublishOnly": "npm run build",
    "prepare": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "pcbway",
    "mcp",
    "model-context-protocol",
    "pcb",
    "pcba",
    "manufacturing",
    "electronics",
    "hardware"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/nabheet/pcbway-mcp-server.git"
  },
  "homepage": "https://github.com/nabheet/pcbway-mcp-server#readme",
  "bugs": {
    "url": "https://github.com/nabheet/pcbway-mcp-server/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.14.1",
    "dotenv": "^17.4.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.14.1",
    "@vitest/coverage-v8": "^4.1.9",
    "typescript": "^5.8.3",
    "vitest": "^4.1.9"
  }
}
